# ==========================================
# คำเตือนความปลอดภัย
# ==========================================
# 1) ไฟล์นี้เป็นตัวอย่างเท่านั้น ห้ามใส่คีย์จริง
# 2) ให้ใส่ค่าจริงในไฟล์ backend/.env (ไฟล์นี้ไม่ควรถูก push)

# =========================
# พื้นฐานระบบ (Core)
# =========================

# พอร์ตที่ Backend จะเปิดใช้งาน
PORT=4000

# URL สำหรับเชื่อมต่อ MongoDB
# หมายเหตุ: ถ้ารันผ่าน Docker Compose ให้ใช้ mongodb://mongodb:27017/chatai
MONGO_URI=mongodb://localhost:27017/chatai

# โดเมนของ Frontend ที่อนุญาตให้เรียก API (CORS)
# ใส่ได้หลายค่าโดยคั่นด้วย comma
FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# คีย์ลับสำหรับเข้ารหัส session (ต้องเปลี่ยนในระบบจริง)
# สามารถใช้คำสั่งในcmd ได้เลย  powershell -NoProfile -Command "[Convert]::ToBase64String((1..48 | ForEach-Object {Get-Random -Minimum 0 -Maximum 256}))"
# ใช้คีย์ที่มีความยาวอย่างน้อย 32 bytes (256 bits) เพื่อความปลอดภัย
# ตัวอย่างคีย์ที่ปลอดภัย: vKky4b3kY41Gt3+xjGR61zxvB02ND1xwA/KLYcUICX88knZHA1rCSy5cnOoS6ABf แล้วเอามาใส่ในไฟล์ .env จริง
SESSION_SECRET=__REQUIRED_SET_IN_BACKEND_DOT_ENV__


# อายุ session (วินาที) เช่น 86400 = 24 ชั่วโมง
SESSION_TTL_SECONDS=86400

# ความเข้มของการ hash รหัสผ่าน (bcrypt)
BCRYPT_SALT_ROUNDS=12


# =========================
# การจำกัดการเรียกใช้งาน (Rate Limit)
# =========================

# หน้าต่างเวลาสำหรับนับคำขอ (มิลลิวินาที) เช่น 60000 = 1 นาที
CHAT_RATE_LIMIT_WINDOW_MS=60000

# จำนวนคำขอสูงสุดต่อช่วงเวลา
CHAT_RATE_LIMIT_MAX_REQUESTS=20


# =========================
# พฤติกรรมระบบแชท (Chat Runtime)
# =========================

# เวลา timeout ของการเรียก AI ต่อครั้ง (มิลลิวินาที)
CHAT_TIMEOUT_MS=30000

# จำนวน token สูงสุดของคำตอบ AI ต่อครั้ง
CHAT_MAX_OUTPUT_TOKENS=1000

# ระดับความสุ่มของคำตอบ (สูง = หลากหลายขึ้น)
CHAT_TEMPERATURE=0.85

# จำนวนตัวอักษรสูงสุดของบริบทเอกสารที่ส่งให้ AI
DOCUMENT_CONTEXT_CHARS=80000

# เวลาพัก API key ที่พลาดก่อนนำกลับมาใช้อีกครั้ง (มิลลิวินาที)
API_KEY_COOLDOWN_MS=60000


# =========================
# ผู้ให้บริการ AI (AI Providers)
# =========================

# Gemini API keys
# ใส่ได้ 1 key หรือหลาย key โดยคั่นด้วย comma: key1,key2,key3
GEMINI_API_KEYS=__SET_IN_BACKEND_DOT_ENV_ONLY__

# โมเดล Gemini ที่ใช้งาน
GEMINI_MODEL=gemini-2.5-flash

# Anthropic API keys
# ใส่ได้ 1 key หรือหลาย key โดยคั่นด้วย comma: key1,key2,key3
ANTHROPIC_API_KEYS=__SET_IN_BACKEND_DOT_ENV_ONLY__

# โมเดล Claude ที่ใช้งาน
CLAUDE_MODEL=claude-3-5-haiku-latest
